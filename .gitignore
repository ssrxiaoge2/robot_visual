# ── Qt / CMake 构建产物 ───────────────────────────────────────
build/
build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
*.pro.user
*.pro.user.*
*.qmake.stash

# ── Qt Creator 工程文件（本地环境相关，不提交）────────────────
.qtcreator/

# ── 可执行文件 / 库 ───────────────────────────────────────────
*.exe
*.out
*.app
*.dll
*.so
*.so.*
*.dylib
*.a
*.lib

# N-ScanHub 厂商 SDK 整包需要随源码提交（包含 Linux/Windows 动态库）
!3rd/NScanHubSdk/
!3rd/NScanHubSdk/**
# 排除 SDK 压缩包中遗留的 Office 临时锁文件
3rd/NScanHubSdk/**/~$*.docx

# ── 编译中间产物 ──────────────────────────────────────────────
*.o
*.obj
*.moc
moc_*.cpp
moc_*.h
qrc_*.cpp
ui_*.h

# ── 日志 / 运行时输出 ─────────────────────────────────────────
Log/
*.log

# ── 操作系统垃圾文件 ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
